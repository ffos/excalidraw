# Self-hosted Excalidraw on Cloudflare Workers.
#
# Copy this file to `.env.production` (or `.env.local`) and set the URL of
# your deployed Worker / Pages app.
#
# All endpoints are served by a single Cloudflare Worker; the same origin is
# used for the static SPA, the scene API, the file API, and the WebSocket
# Durable Object.

MODE="production"

# Public origin where your Worker / Pages app lives.
# Examples:
#   https://excalidraw.example.com
#   https://my-app.workers.dev
VITE_APP_PUBLIC_URL=https://excalidraw.example.com

# Scene share-link API (replaces json.excalidraw.com).
VITE_APP_BACKEND_V2_GET_URL=${VITE_APP_PUBLIC_URL}/api/v2/
VITE_APP_BACKEND_V2_POST_URL=${VITE_APP_PUBLIC_URL}/api/v2/post/

# Real-time collaboration WebSocket (Durable Object). Same origin is fine.
VITE_APP_WS_SERVER_URL=${VITE_APP_PUBLIC_URL}

# File storage (R2) — must end without a trailing slash.
VITE_APP_FILES_API_URL=${VITE_APP_PUBLIC_URL}/api/files

# Per-room scene persistence (Durable Object) — must end without trailing slash.
VITE_APP_ROOMS_API_URL=${VITE_APP_PUBLIC_URL}/api/room

# Disable third-party features that aren't part of self-hosting.
VITE_APP_ENABLE_TRACKING=false
VITE_APP_DISABLE_SENTRY=true

# Optional: external libraries browser. Leave blank to disable.
VITE_APP_LIBRARY_URL=
VITE_APP_LIBRARY_BACKEND=

# Optional: Excalidraw+ export integration. Leave blank to disable.
VITE_APP_PLUS_LP=
VITE_APP_PLUS_APP=
VITE_APP_PLUS_EXPORT_BUCKET=
VITE_APP_PLUS_EXPORT_PUBLIC_KEY=

# Optional: AI backend. Leave blank to disable.
VITE_APP_AI_BACKEND=
